# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend for production, Mailpit SMTP for dev)
RESEND_API_KEY=re_xxx
EMAIL_FROM=The Captain Boat <noreply@thecaptainboat.com>
SMTP_HOST=localhost
SMTP_PORT=1025

# BNESIM (eSIM provider)
BNESIM_API_KEY=your-operator-username
BNESIM_API_SECRET=your-operator-password
BNESIM_API_URL=https://api.bnesim.com/v2.0

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
RESERVATION_JWT_SECRET=change-this-to-a-random-64-char-string

# Rate Limiting (Upstash) — optional for dev
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chatbot RAG (Vercel AI SDK + OpenAI)
OPENAI_API_KEY=sk-xxx

# WhatsApp redirect (chatbot)
NEXT_PUBLIC_WHATSAPP_NUMBER=33600000000

# Apple Wallet (optional — passes skipped if missing)
APPLE_PASS_TYPE_ID=pass.com.thecaptainboat.ticket
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_KEY_PASSPHRASE=

# Google Wallet (optional — passes skipped if missing)
